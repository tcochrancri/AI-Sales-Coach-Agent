OPENAI_API_KEY=
VITE_CHATKIT_WORKFLOW_ID=wf_...
# Optional model override for grant campaign endpoint
GRANT_CAMPAIGN_MODEL=gpt-4.1
# Optional backend log verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# For production: frontend URL (used by frontend build)
VITE_API_URL=
# Backend CORS: comma-separated allowed origins (default: ai-sales-coach-agent-production)
CORS_ORIGINS=

# --- HubSpot MCP (campaign modal "HubSpot" tab) ---
# Backend only. Required for POST /api/hubspot/context.
# Set these on Railway for the backend service (same values as local if you use HubSpot there).
#
# Base URL of YOUR proxy that forwards to HubSpot MCP (not optional).
HUBSPOT_MCP_BASE_URL=
#
# Auth (pick one path):
# Recommended: install id for server-managed refresh (see your HubSpot MCP / OpenAI connector docs).
HUBSPOT_MCP_INSTALL_ID=
# Optional with install-based flows:
HUBSPOT_MCP_REFRESH_TOKEN=
#
# Legacy: static OAuth access token (short-lived; set on Railway when it expires).
# One line only — do not paste a second KEY=value on the next line (breaks HTTP headers).
HUBSPOT_MCP_ACCESS_TOKEN=
#
# Legacy: token resolved via your proxy
HUBSPOT_MCP_TOKEN_ID=
#
# Optional overrides:
HUBSPOT_MCP_BEARER=
HUBSPOT_MCP_SERVER_URL=https://mcp.hubspot.com

